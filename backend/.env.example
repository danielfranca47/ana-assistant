# Conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ana_assistant"

# Segredo para geração e validação de tokens JWT (use uma string longa e aleatória)
JWT_SECRET="troque-este-valor-por-uma-string-aleatoria-longa"

# Porta do servidor Express
PORT=3001

# Origem permitida pelo CORS (URL do frontend)
CORS_ORIGIN="http://localhost:5173"

# Ambiente de execução: development | test | production
NODE_ENV="development"

# Chave da API Anthropic (para integração com a Ana)
ANTHROPIC_API_KEY=""
